PORT=3001
NODE_ENV=development

# Em produção: obrigatório, mínimo 32 caracteres, aleatório (nunca commite o valor real).
JWT_SECRET=troque-em-producao-use-string-longa-e-aleatoria-minimo-32-chars

# PostgreSQL — alinhado ao Prisma (migrations do repo são para Postgres).
# Local: docker compose up -d na raiz do monorepo, depois:
DATABASE_URL="postgresql://estante:estante@localhost:5432/estante?schema=public"

# Produção Render: DATABASE_URL vem do Postgres gerenciado (Blueprint injeta automaticamente).

# Vercel — URL exata do site (CORS). Várias origens: separadas por vírgula.
# FRONTEND_URL=http://localhost:5173,https://seu-app.vercel.app

# Previews Vercel (*.vercel.app) sem listar uma a uma:
# CORS_ALLOW_VERCEL_PREVIEWS=1

# Proxy (Render, etc.). Padrão: 1
# TRUST_PROXY_HOPS=1
