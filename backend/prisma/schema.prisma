generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PLUS
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  password                  String
  plan                      Plan      @default(FREE)
  planEndsAt                DateTime?
  /** Aceite do aviso de privacidade no cadastro (LGPD — demonstração). */
  privacyNoticeAcceptedAt   DateTime?
  createdAt                 DateTime  @default(now())
}

model Book {
  id        String  @id @default(cuid())
  title     String
  author    String
  synopsis  String
  coverUrl  String?
  isPremium Boolean @default(false)
}
